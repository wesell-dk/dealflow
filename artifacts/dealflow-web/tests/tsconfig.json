{
  "extends": "../../../tsconfig.base.json",
  "include": ["**/*.ts", "**/*.tsx", "../src/**/*"],
  "compilerOptions": {
    "noEmit": true,
    "jsx": "react-jsx",
    "lib": ["esnext", "dom", "dom.iterable"],
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "paths": {
      "@/*": ["../src/*"]
    }
  }
}

{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "export NODE_ENV=development && pnpm run build && pnpm run start",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tests/tsconfig.json --noEmit",
    "test:isolation": "node --import tsx --test --test-reporter=spec tests/tenant-isolation.test.ts tests/validation-negative.test.ts",
    "test:renewals": "node --import tsx --test --test-reporter=spec tests/renewals.test.ts",
    "test": "pnpm run test:isolation && pnpm run test:renewals"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@google-cloud/storage": "^7.19.0",
    "@react-pdf/renderer": "^4.5.1",
    "@swc/helpers": "^0.5.21",
    "@types/react": "catalog:",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "archiver": "^7.0.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "google-auth-library": "^10.6.2",
    "mammoth": "1.8.0",
    "pdf-parse": "1.1.4",
    "pino": "^9",
    "pino-http": "^10",
    "react": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "@types/pdf-parse": "^1.1.5",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0",
    "tsx": "catalog:"
  }
}
